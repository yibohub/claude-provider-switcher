[Unit]
Description=Claude Code Provider Switcher Web UI
After=network.target

[Service]
Type=simple
User=yeebo
WorkingDirectory=/home/yeebo/myproject/claude-provider-switcher
ExecStart=/usr/bin/python3 /home/yeebo/myproject/claude-provider-switcher/app.py --host 0.0.0.0 --port 5000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
